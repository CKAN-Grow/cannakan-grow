{
  "name": "cannakan-grow",
  "private": true,
  "version": "1.0.0",
  "dependencies": {
    "qrcode": "^1.5.4",
    "qrcodejs": "^1.0.0",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "supabase": "2.109.1"
  },
  "scripts": {
    "build": "node ./scripts/build-config.mjs",
    "generate:profile-migration": "node ./scripts/generate-profile-columns-migration.mjs",
    "demo:seed": "node ./scripts/local-demo/seed.mjs --local-demo-command=seed",
    "demo:clear": "node ./scripts/local-demo/clear.mjs --local-demo-command=clear",
    "demo:reset": "node ./scripts/local-demo/reset.mjs --local-demo-command=reset",
    "demo:verify": "node ./scripts/local-demo/verify.mjs --local-demo-command=verify",
    "security:access-audit": "node ./scripts/security-access-regression-check.mjs",
    "security:fingerprint": "node ./scripts/security/security-fingerprint.mjs",
    "security:function-audit": "node ./scripts/security/function-access-audit.mjs",
    "security:function-hardening": "node ./scripts/security-function-hardening-regression-check.mjs",
    "security:verify": "node ./scripts/security/run-security-verification.mjs",
    "qa:founder": "node ./scripts/run-founder-admin-qa-sweep.js",
    "qa:developer-scenarios": "node ./scripts/developer-scenarios-regression-check.mjs",
    "qa:grow-identity": "node ./scripts/grow-identity-phase1-regression-check.mjs",
    "qa:semantic-colors": "node ./scripts/semantic-color-system-regression-check.js",
    "qa:single-seed-position-methods": "node ./scripts/single-seed-position-method-regression-check.js",
    "test:e2e": "playwright test --project=founder-desktop",
    "test:e2e:mobile": "playwright test --project=mobile-390 --project=mobile-430 --project=tablet-768"
  }
}
